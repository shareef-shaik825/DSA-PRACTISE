#include <iostream>
using namespace std;

int findPeak(int data[], int n) {
    int low = 0;
    int high = n - 1;
    while (low <= high) {
        int mid = (low + high) / 2;

        if (data[mid] > data[mid - 1] && data[mid] > data[mid + 1]) {
            return data[mid];
        }
        else if (data[mid] < data[mid - 1]) {
            high = mid - 1;
        }
        else {
            low = mid + 1;
        }
    }
    return -1;
}
int main() {
    int data[] = {1, 3, 8, 12, 4, 2};
    int n = sizeof(data) / sizeof(data[0]);
    cout << findPeak(data, n);
    return 0;
}
